# Copy to .env.local and fill in to activate the Supabase backend (step 5).
# Until these are set, the app runs fully on the offline LocalOnlyAdapter (no backend).

# From your Supabase project: Settings → API (Keys & Credentials).
# The key is the PUBLIC client key — either the legacy "anon" JWT or the newer
# publishable key (sb_publishable_…). Safe in the browser; RLS protects the data.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side ONLY (never exposed to the browser). Settings → API → service_role / secret key.
# NOT used by the static-export app (Phase 1 syncs purely client-side via RLS + the
# sync_capture_ops RPC). Reserved for future server routes; do not commit a real value.
SUPABASE_SERVICE_ROLE_KEY=
