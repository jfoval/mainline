# Copy to .env.local and fill in to activate the Supabase backend (step 5).
# Until these are set, the app runs fully on the offline LocalOnlyAdapter (no backend).

# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side ONLY (never exposed to the browser). Settings → API → service_role.
# Needed for privileged sync/maintenance routes; do not commit a real value.
SUPABASE_SERVICE_ROLE_KEY=
